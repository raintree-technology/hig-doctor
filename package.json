{
  "private": true,
  "scripts": {
    "validate": "node packages/hig-doctor/src/cli.js . --verbose",
    "validate:strict": "node packages/hig-doctor/src/cli.js . --strict",
    "validate:score": "node packages/hig-doctor/src/cli.js . --score",
    "validate:tui": "node packages/hig-doctor/src/cli.js . --tui",
    "sync:audit-patterns": "cp packages/hig-doctor/src-termcast/src/patterns.ts website/lib/audit/patterns.ts",
    "test": "bun --cwd packages/hig-doctor test && node --test test/workflow-security.test.mjs test/audit-patterns-sync.test.mjs",
    "test:security": "node --test test/workflow-security.test.mjs",
    "test:audit-sync": "node --test test/audit-patterns-sync.test.mjs"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "website",
    "packages/hig-doctor",
    "packages/hig-doctor/src-mcp",
    "packages/hig-doctor/src-termcast",
    "demos/remotion-hig-doctor"
  ]
}
