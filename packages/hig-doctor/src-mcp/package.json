{
  "name": "hig-mcp",
  "version": "0.1.0",
  "mcpName": "io.github.raintree-technology/hig-doctor",
  "description": "MCP server exposing Apple HIG skills and audit tool for AI coding agents",
  "type": "module",
  "bin": {
    "hig-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/bun": "^1.3.3",
    "@types/node": "^20",
    "esbuild": "^0.25.0",
    "typescript": "^7.0.2"
  }
}
