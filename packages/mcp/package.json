{
  "name": "hig-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.raintree-technology/hig-doctor",
  "description": "HIG Doctor MCP server exposing Apple HIG skills and project audits to AI coding agents",
  "type": "module",
  "bin": {
    "hig-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": "24.x"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raintree-technology/hig-doctor.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/raintree-technology/hig-doctor/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/raintree-technology/hig-doctor/issues"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --alias:@hig-doctor/core=../core/src/index.ts --external:typescript --banner:js=\"#!/usr/bin/env node\" && bun run bundle:skills",
    "bundle:skills": "rm -rf dist/skills && cp -R ../../skills dist/skills",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/bun": "^1.3.3",
    "@types/node": "^20",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
